// Schema inicial — adicionar Address/Lote/Invoice/Notification em iterações futuras
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  comprador
  financeiro
}

enum PedidoStatus {
  rascunho
  aguardando_cotacao
  cotado
  confirmado
  em_separacao
  enviado
  entregue
  cancelado
}

enum MovimentacaoTipo {
  entrada
  saida
  ajuste
  perda
  transferencia
}

enum ContaTipo {
  pagar
  receber
}

enum ContaStatus {
  aberta
  paga
  vencida
  cancelada
}

enum AgrupamentoStatus {
  aberto // acumulando itens de pedidos
  em_cotacao // fechado pelo admin, aguardando lances de fornecedores
  cotado // fornecedor vencedor escolhido
  finalizado
  cancelado
}

enum MedicamentoCategoria {
  estetica
  higiene
  descartaveis
  material
  antissepticos
  solucoes
  insumos
}

enum NotificacaoTipo {
  pedido
  alerta
  sistema
}

model User {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  passwordHash String
  empresa      String?
  role         UserRole @default(comprador)
  bloqueado    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pedidos        Pedido[]
  movimentacoes  Movimentacao[]
  estoqueItens   EstoqueItem[]
  passwordResets PasswordReset[]
  pushTokens     PushToken[]
  enderecos      Endereco[]
  notificacoes   Notificacao[]
  auditLogs      AuditLog[]
  contas         Conta[]
}

model PushToken {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  plataforma   String // ios | android
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  criadoEm  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Medicamento {
  id             String               @id @default(uuid())
  nome           String
  principioAtivo String?
  fabricante     String?
  apresentacao   String?
  dosagem        String?
  categoria      MedicamentoCategoria
  precoUnitario  Decimal              @db.Decimal(12, 2)
  custo          Decimal?             @db.Decimal(12, 2)
  ean            String?              @unique
  receituario    Boolean              @default(false)
  ativo          Boolean              @default(true)
  imagemUrl      String?
  criadoEm       DateTime             @default(now())
  atualizadoEm   DateTime             @updatedAt

  itensPedido   PedidoItem[]
  estoque       EstoqueItem[]
  movimentacoes Movimentacao[]
  agrupamentos  Agrupamento[]

  @@index([nome])
  @@index([categoria])
}

model Pedido {
  id           String       @id @default(uuid())
  numero       String       @unique
  status       PedidoStatus @default(rascunho)
  total        Decimal      @default(0) @db.Decimal(12, 2)
  observacao   String?
  usuarioId    String
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  // Destino de entrega: FK para o endereço + snapshot textual congelado
  // (preserva o histórico mesmo se o endereço for editado/removido).
  enderecoEntregaId    String?
  enderecoEntregaTexto String?

  // Motor de cotação
  cotacaoEnviadaEm  DateTime?
  cotacaoValidaAte  DateTime?
  prazoEntregaDias  Int?
  cotacaoObservacao String?
  respondidaEm      DateTime?

  usuario         User         @relation(fields: [usuarioId], references: [id])
  enderecoEntrega Endereco?    @relation(fields: [enderecoEntregaId], references: [id], onDelete: SetNull)
  itens           PedidoItem[]
  contas          Conta[]

  @@index([usuarioId])
  @@index([status])
  @@index([criadoEm])
}

model PedidoItem {
  id            String  @id @default(uuid())
  pedidoId      String
  medicamentoId String
  quantidade    Int
  precoUnitario Decimal @db.Decimal(12, 2)
  disponivel    Boolean @default(true)
  observacao    String?
  agrupamentoId String?

  pedido      Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  medicamento Medicamento  @relation(fields: [medicamentoId], references: [id])
  agrupamento Agrupamento? @relation(fields: [agrupamentoId], references: [id])

  @@index([pedidoId])
  @@index([agrupamentoId])
}

// Agrupamento — junta itens do mesmo medicamento de várias clínicas
// para cotação em volume com fornecedores (compra coletiva).
model Agrupamento {
  id            String            @id @default(uuid())
  numero        String            @unique
  medicamentoId String
  status        AgrupamentoStatus @default(aberto)
  publicToken   String            @unique @default(uuid()) // link público p/ lance de fornecedor (fase 2)
  observacao    String?
  criadoEm      DateTime          @default(now())
  fechadoEm     DateTime?
  atualizadoEm  DateTime          @updatedAt

  // Rastreabilidade (Vigilância Sanitária) — preenchida ao finalizar a compra
  lote         String?
  validade     DateTime?
  fabricante   String?
  notaFiscal   String?
  finalizadoEm DateTime?

  medicamento Medicamento  @relation(fields: [medicamentoId], references: [id])
  itens       PedidoItem[]
  lances      Lance[]

  @@index([status])
  @@index([medicamentoId])
}

// Fornecedor — quem oferta preço nos agrupamentos
model Fornecedor {
  id           String   @id @default(uuid())
  nome         String
  cnpj         String?  @unique
  email        String?
  telefone     String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lances Lance[]
}

// Lance — oferta de um fornecedor para um agrupamento
model Lance {
  id               String   @id @default(uuid())
  agrupamentoId    String
  fornecedorId     String?
  fornecedorNome   String
  precoUnitario    Decimal  @db.Decimal(12, 2)
  prazoEntregaDias Int
  observacao       String?
  vencedor         Boolean  @default(false)
  criadoEm         DateTime @default(now())

  agrupamento Agrupamento @relation(fields: [agrupamentoId], references: [id], onDelete: Cascade)
  fornecedor  Fornecedor? @relation(fields: [fornecedorId], references: [id])

  @@index([agrupamentoId])
  @@index([fornecedorId])
}

model EstoqueItem {
  id            String    @id @default(uuid())
  medicamentoId String
  usuarioId     String
  quantidade    Int       @default(0)
  lote          String?
  validade      DateTime?
  localizacao   String?
  atualizadoEm  DateTime  @updatedAt

  medicamento Medicamento @relation(fields: [medicamentoId], references: [id])
  usuario     User        @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, medicamentoId, lote])
  @@index([medicamentoId])
}

model Movimentacao {
  id            String           @id @default(uuid())
  medicamentoId String
  usuarioId     String
  tipo          MovimentacaoTipo
  quantidade    Int
  lote          String?
  validade      DateTime?
  motivo        String?
  criadoEm      DateTime         @default(now())

  medicamento Medicamento @relation(fields: [medicamentoId], references: [id])
  usuario     User        @relation(fields: [usuarioId], references: [id])

  @@index([medicamentoId])
  @@index([usuarioId])
  @@index([criadoEm])
}

model Conta {
  id           String      @id @default(uuid())
  tipo         ContaTipo
  descricao    String
  valor        Decimal     @db.Decimal(12, 2)
  vencimento   DateTime
  status       ContaStatus @default(aberta)
  pagoEm       DateTime?
  pedidoId     String?
  usuarioId    String? // dono da conta (clínica) — escopo multi-tenant
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  pedido  Pedido? @relation(fields: [pedidoId], references: [id])
  usuario User?   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([vencimento])
  @@index([pedidoId])
  @@index([usuarioId])
}

model Endereco {
  id           String   @id @default(uuid())
  usuarioId    String
  apelido      String
  logradouro   String
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String
  uf           String
  cep          String
  principal    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  usuario User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos Pedido[]

  @@index([usuarioId])
}

model Notificacao {
  id        String          @id @default(uuid())
  usuarioId String
  tipo      NotificacaoTipo @default(sistema)
  titulo    String
  corpo     String
  pedidoId  String?
  lidaEm    DateTime?
  criadoEm  DateTime        @default(now())

  usuario User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, lidaEm])
}

// Parâmetros de negócio editáveis no back-office (sem deploy): limiar de
// estoque baixo, validade da cotação, etc. Key-value simples (valor como texto).
model ConfiguracaoSistema {
  chave        String   @id
  valor        String
  descricao    String?
  atualizadoEm DateTime @updatedAt
}

// Trilha de auditoria de ações sensíveis (status de pedido, escolha de vencedor,
// baixa de conta, bloqueio/exclusão de usuário). Json aqui é payload de auditoria
// (antes/depois), não dado de domínio. atorId SetNull para não travar exclusão LGPD.
model AuditLog {
  id          String   @id @default(uuid())
  atorId      String?
  acao        String
  entidade    String
  entidadeId  String
  dadosAntes  Json?
  dadosDepois Json?
  criadoEm    DateTime @default(now())

  ator User? @relation(fields: [atorId], references: [id], onDelete: SetNull)

  @@index([entidade, entidadeId])
  @@index([atorId])
  @@index([criadoEm])
}
