// Schema inicial — adicionar Address/Lote/Invoice/Notification em iterações futuras
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  comprador
  financeiro
}

enum PedidoStatus {
  rascunho
  aguardando_cotacao
  cotado
  confirmado
  em_separacao
  enviado
  entregue
  cancelado
}

enum MovimentacaoTipo {
  entrada
  saida
  ajuste
  perda
  transferencia
}

enum ContaTipo {
  pagar
  receber
}

enum ContaStatus {
  aberta
  paga
  vencida
  cancelada
}

model User {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  passwordHash String
  empresa      String?
  role         UserRole @default(comprador)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  pedidos       Pedido[]
  movimentacoes Movimentacao[]
}

model Medicamento {
  id             String   @id @default(uuid())
  nome           String
  principioAtivo String?
  fabricante     String?
  apresentacao   String?
  dosagem        String?
  categoria      String
  precoUnitario  Decimal  @db.Decimal(12, 2)
  custo          Decimal? @db.Decimal(12, 2)
  ean            String?  @unique
  receituario    Boolean  @default(false)
  imagemUrl      String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  itensPedido   PedidoItem[]
  estoque       EstoqueItem[]
  movimentacoes Movimentacao[]

  @@index([nome])
  @@index([categoria])
}

model Pedido {
  id           String       @id @default(uuid())
  numero       String       @unique
  status       PedidoStatus @default(rascunho)
  total        Decimal      @db.Decimal(12, 2) @default(0)
  observacao   String?
  usuarioId    String
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt

  // Motor de cotação
  cotacaoEnviadaEm  DateTime?
  cotacaoValidaAte  DateTime?
  prazoEntregaDias  Int?
  cotacaoObservacao String?
  respondidaEm      DateTime?

  usuario User         @relation(fields: [usuarioId], references: [id])
  itens   PedidoItem[]
  contas  Conta[]

  @@index([usuarioId])
  @@index([status])
}

model PedidoItem {
  id            String  @id @default(uuid())
  pedidoId      String
  medicamentoId String
  quantidade    Int
  precoUnitario Decimal @db.Decimal(12, 2)
  disponivel    Boolean @default(true)
  observacao    String?

  pedido      Pedido      @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  medicamento Medicamento @relation(fields: [medicamentoId], references: [id])

  @@index([pedidoId])
}

model EstoqueItem {
  id            String    @id @default(uuid())
  medicamentoId String
  quantidade    Int       @default(0)
  lote          String?
  validade      DateTime?
  localizacao   String?
  atualizadoEm  DateTime  @updatedAt

  medicamento Medicamento @relation(fields: [medicamentoId], references: [id])

  @@unique([medicamentoId, lote])
}

model Movimentacao {
  id            String           @id @default(uuid())
  medicamentoId String
  usuarioId     String
  tipo          MovimentacaoTipo
  quantidade    Int
  lote          String?
  validade      DateTime?
  motivo        String?
  criadoEm      DateTime         @default(now())

  medicamento Medicamento @relation(fields: [medicamentoId], references: [id])
  usuario     User        @relation(fields: [usuarioId], references: [id])

  @@index([medicamentoId])
  @@index([criadoEm])
}

model Conta {
  id          String      @id @default(uuid())
  tipo        ContaTipo
  descricao   String
  valor       Decimal     @db.Decimal(12, 2)
  vencimento  DateTime
  status      ContaStatus @default(aberta)
  pagoEm      DateTime?
  pedidoId    String?
  criadoEm    DateTime    @default(now())
  atualizadoEm DateTime   @updatedAt

  pedido Pedido? @relation(fields: [pedidoId], references: [id])

  @@index([status])
  @@index([vencimento])
}
