{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "20.18.0",
      "pnpm": "10.30.3",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sistemas-api.cusrzj.easypanel.host"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "node": "20.18.0",
      "pnpm": "10.30.3",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://sistemas-api.cusrzj.easypanel.host"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
