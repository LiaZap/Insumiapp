{
  "expo": {
    "name": "Insumia",
    "slug": "insumia",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "insumia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B498C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.insumia.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B498C"
      },
      "package": "com.insumia.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B498C",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://sistemas-api.cusrzj.easypanel.host",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "edc9946a-379e-4298-a901-bc4c8f841751"
      }
    },
    "owner": "paulomelo777",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/edc9946a-379e-4298-a901-bc4c8f841751"
    }
  }
}
